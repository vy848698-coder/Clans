# Block direct browser access to sensitive files.
# (db.php is still usable via require/include from PHP — this only blocks
#  someone typing the file's URL directly. submit-contact.php stays public.)

<FilesMatch "(?i)\.(sql|md|log|json|lock)$">
    Require all denied
</FilesMatch>

<FilesMatch "^(db|auth_lib|api_guard)\.php$">
    Require all denied
</FilesMatch>

# Don't list directory contents
Options -Indexes

# Pass the HTTP Authorization header (the dashboard's "Bearer <token>") through to
# PHP. Some hosts (incl. Railway/Apache-CGI) strip it by default, which would make
# every logged-in API call fail with 401. Safe to keep everywhere.
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
</IfModule>
SetEnvIf Authorization "(.*)" HTTP_AUTHORIZATION=$1

# Send old blog.html links to the new dynamic blog.php
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^blog\.html$ /ClansMachina/blog.php [R=301,L]
</IfModule>

# partials/ are includes, never meant to be opened directly
<FilesMatch "^(nav|footer)\.php$">
    Require all denied
</FilesMatch>

# --- Performance: compression + browser caching ---

# Gzip text-based assets (HTML, CSS, JS, fonts, SVG)
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml \
        application/javascript application/json image/svg+xml \
        application/x-font-ttf application/vnd.ms-fontobject font/ttf font/otf
</IfModule>

# Tell browsers to cache static assets so repeat visits don't re-download them
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg   "access plus 1 year"
    ExpiresByType image/png    "access plus 1 year"
    ExpiresByType image/webp   "access plus 1 year"
    ExpiresByType image/gif    "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType text/css     "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType font/ttf     "access plus 1 year"
    ExpiresByType font/otf     "access plus 1 year"
    ExpiresByType application/vnd.ms-fontobject "access plus 1 year"
    ExpiresDefault             "access plus 2 days"
</IfModule>
